# Copy this file to apps/server/.env and fill in the values.
# Also copy the web section to apps/web/.env.

# ── API Server (apps/server/.env) ────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/subbox

# Better Auth
# IMPORTANT: BETTER_AUTH_URL must be the web app URL (not the API server),
# because OAuth callbacks are proxied through the web app (/api/auth/*).
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string-min
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Google OAuth (https://console.cloud.google.com)
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
# Required scopes: openid, email, profile, https://www.googleapis.com/auth/youtube.readonly
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# YouTube Data API v3 (https://console.cloud.google.com)
YOUTUBE_API_KEY=your-youtube-api-key

# ── Web App (apps/web/.env) ────────────────────────────────────────────────────

# Points to the API server for Next.js rewrites (server-side only)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Skip env validation during `next build` (set to true in CI/build environments)
SKIP_ENV_VALIDATION=true
